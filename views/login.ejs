<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Login ke SUKAFTI — Sistem Informasi Survey Kerja Sama FTI Universitas Andalas." />
  <title>Login | SUKAFTI</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/basecoat-css@latest/dist/basecoat.min.css" />
  <link rel="stylesheet" href="/css/login.css" />
</head>

<body>

  <div class="split-layout">

    <aside class="panel-left" aria-hidden="true">

      <div class="panel-left__logo">
        <img src="/image/fti logo.jpg" alt="Logo FTI Unand" class="logo-img" />
        <div class="logo-text">
          <span class="logo-wordmark">SUKAFTI</span>
          <span class="logo-tagline">Survey Kerjasama FTI</span>
        </div>
      </div>

      <div class="carousel" id="left-carousel" aria-label="Fitur SUKAFTI">

        <% if (activeTab === 'admin') { %>
          <!-- ================= CAROUSEL ADMIN ================= -->
          <div class="carousel__slide carousel__slide--active" data-index="0">
            <div class="panel-left__illus">
              <img src="/image/survey_illustration.png" alt="Ilustrasi Survey" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Kelola Survey Kerja Sama<br />Mitra Industri FTI</h2>
              <p class="panel-left__desc">
                Platform digital untuk mengelola data kerjasama dan survei mitra industri
                Fakultas Teknologi Informasi, Universitas Andalas.
              </p>
            </div>
          </div>

          <div class="carousel__slide" data-index="1">
            <div class="panel-left__illus">
              <img src="/image/survey_slide2.png" alt="Ilustrasi Analitik Data" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Analitik Data<br />Berbasis Digital</h2>
              <p class="panel-left__desc">
                Visualisasi hasil survey secara real-time dengan laporan
                yang mudah dibaca dan diunduh.
              </p>
            </div>
          </div>

          <div class="carousel__slide" data-index="2">
            <div class="panel-left__illus">
              <img src="/image/survey_slide3.png" alt="Ilustrasi Kerjasama" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Jalin Kerja Sama<br />yang Berkelanjutan</h2>
              <p class="panel-left__desc">
                Pantau perkembangan kemitraan dan rekam seluruh riwayat
                kerja sama FTI Universitas Andalas.
              </p>
            </div>
          </div>
        <% } else { %>
          <!-- ================= CAROUSEL MITRA ================= -->
          <div class="carousel__slide carousel__slide--active" data-index="0">
            <div class="panel-left__illus">
              <img src="/image/survey_illustration.png" alt="Ilustrasi Mitra" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Selamat Datang,<br />Mitra Industri FTI</h2>
              <p class="panel-left__desc">
                Partisipasi Anda sangat berarti untuk meningkatkan kualitas lulusan dan layanan Fakultas Teknologi Informasi Universitas Andalas.
              </p>
            </div>
          </div>

          <div class="carousel__slide" data-index="1">
            <div class="panel-left__illus">
              <img src="/image/survey_slide2.png" alt="Sinergi Akademik" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Sinergi Akademik<br />&amp; Industri</h2>
              <p class="panel-left__desc">
                Masukan Anda membantu kami menyelaraskan kurikulum dengan kebutuhan industri saat ini dan di masa depan.
              </p>
            </div>
          </div>

          <div class="carousel__slide" data-index="2">
            <div class="panel-left__illus">
              <img src="/image/survey_slide3.png" alt="Terima Kasih" class="illus-img" />
            </div>
            <div class="panel-left__copy">
              <h2 class="panel-left__tagline">Terima Kasih Atas<br />Kerjasama Anda</h2>
              <p class="panel-left__desc">
                Kami sangat mengapresiasi waktu dan kontribusi berharga Anda dalam mengisi survey ini.
              </p>
            </div>
          </div>
        <% } %>

      </div><!-- /.carousel -->

      <div class="panel-left__dots" role="tablist" aria-label="Slide">
        <button class="dot dot--active" data-slide="0" onclick="goToSlide(0)" aria-label="Slide 1" aria-selected="true"></button>
        <button class="dot" data-slide="1" onclick="goToSlide(1)" aria-label="Slide 2" aria-selected="false"></button>
        <button class="dot" data-slide="2" onclick="goToSlide(2)" aria-label="Slide 3" aria-selected="false"></button>
      </div>

      <div class="deco deco--tl" aria-hidden="true"></div>
      <div class="deco deco--br" aria-hidden="true"></div>
    </aside>

    <main class="panel-right" role="main">
      <div class="form-container">

        <div class="form-header">
          <h1 class="form-title">Masuk ke Sistem</h1>
          <p class="form-subtitle">
            <% if (activeTab === 'admin') { %>
              Login sebagai Administrator SUKAFTI
            <% } else { %>
              Login sebagai Mitra Industri FTI
            <% } %>
          </p>
        </div>

        <% if (activeTab === 'admin') { %>
          <!-- ── PANEL ADMIN ──────────────────── -->
          <section id="panel-admin" class="tab-panel">

            <% if (locals.error && error && activeTab === 'admin') { %>
            <div class="alert-error" role="alert">
              <i data-lucide="alert-circle" class="alert-icon"></i>
              <span><%= error %></span>
            </div>
            <% } %>

            <form action="/login" method="POST" class="login-form" novalidate>
              <div class="field">
                <label for="admin-email" class="field__label">Email</label>
                <div class="field__wrap">
                  <i data-lucide="mail" class="field__icon"></i>
                  <input type="email" id="admin-email" name="email" class="field__input"
                    placeholder="admin@fti.unand.ac.id" autocomplete="email" required />
                </div>
              </div>

              <div class="field">
                <label for="admin-password" class="field__label">Password</label>
                <div class="field__wrap">
                  <i data-lucide="lock" class="field__icon"></i>
                  <input type="password" id="admin-password" name="password" class="field__input"
                    placeholder="Masukkan password" autocomplete="current-password" required />
                  <button type="button" class="field__eye" onclick="togglePw('admin-password', this)"
                    aria-label="Tampilkan password">
                    <i data-lucide="eye"></i>
                  </button>
                </div>
              </div>

              <button type="submit" id="btn-admin-login" class="btn btn--primary">
                <i data-lucide="log-in" class="btn__icon"></i>
                Masuk sebagai Admin
              </button>
            </form>

            <div class="divider"><span>atau</span></div>

            <div class="alt-action">
              <span class="alt-action__text">Bukan Admin?</span>
              <a href="/login-mitra" class="btn btn--ghost-muted">
                <i data-lucide="building-2" class="btn__icon"></i>
                Masuk sebagai Mitra
              </a>
            </div>
          </section>
        <% } else { %>
          <!-- ── PANEL MITRA ──────────────────── -->
          <section id="panel-mitra" class="tab-panel">

            <% if (locals.error && error && activeTab === 'mitra') { %>
            <div class="alert-error" role="alert">
              <i data-lucide="alert-circle" class="alert-icon"></i>
              <span><%= error %></span>
            </div>
            <% } %>

            <p class="mitra-desc">
              Masukkan data diri dan PIN perusahaan Anda untuk mengakses survey kerjasama.
            </p>

            <form action="/api/auth/mitra-login" method="POST" class="login-form" novalidate>

              <div class="field">
                <label for="mitra-nama" class="field__label">Nama Lengkap</label>
                <div class="field__wrap">
                  <i data-lucide="user" class="field__icon"></i>
                  <input type="text" id="mitra-nama" name="nama" class="field__input"
                    placeholder="Masukkan nama lengkap" autocomplete="name" required />
                </div>
              </div>

              <div class="field">
                <label for="mitra-jabatan" class="field__label">Jabatan</label>
                <div class="field__wrap">
                  <i data-lucide="briefcase" class="field__icon"></i>
                  <input type="text" id="mitra-jabatan" name="jabatan" class="field__input"
                    placeholder="Contoh: HRD Manager, Direktur, dll." required />
                </div>
              </div>

              <div class="field">
                <label for="mitra-perusahaan" class="field__label">Perusahaan</label>
                <div class="field__wrap field__wrap--select">
                  <i data-lucide="building-2" class="field__icon"></i>
                  <select id="mitra-perusahaan" name="perusahaan_id" class="field__input field__select" required>
                    <option value="" disabled selected>-- Pilih perusahaan --</option>
                    <% if (locals.perusahaan && perusahaan.length > 0) { %>
                      <% perusahaan.forEach(function(p) { %>
                        <option value="<%= p.id %>"><%= p.nama_perusahaan %></option>
                      <% }); %>
                    <% } else { %>
                      <option value="" disabled>Belum ada perusahaan terdaftar</option>
                    <% } %>
                  </select>
                  <i data-lucide="chevron-down" class="field__icon field__icon--right"></i>
                </div>
              </div>

              <div class="field">
                <label for="mitra-pin" class="field__label">PIN Perusahaan</label>
                <div class="field__wrap">
                  <i data-lucide="key-round" class="field__icon"></i>
                  <input type="password" id="mitra-pin" name="pin" class="field__input"
                    placeholder="Masukkan PIN perusahaan" maxlength="20" autocomplete="current-password" required />
                  <button type="button" class="field__eye" onclick="togglePw('mitra-pin', this)"
                    aria-label="Tampilkan PIN">
                    <i data-lucide="eye"></i>
                  </button>
                </div>
                <p class="field__hint">PIN diberikan oleh administrator SUKAFTI kepada perusahaan Anda.</p>
              </div>

              <button type="submit" id="btn-mitra-login" class="btn btn--secondary">
                <i data-lucide="arrow-right-circle" class="btn__icon"></i>
                Masuk ke Sistem
              </button>
            </form>

            <div class="divider"><span>atau</span></div>

            <div class="alt-action">
              <span class="alt-action__text">Bukan Mitra?</span>
              <a href="/login" class="btn btn--ghost-muted">
                <i data-lucide="shield-check" class="btn__icon"></i>
                Masuk sebagai Admin
              </a>
            </div>
          </section>
        <% } %>

        <p class="form-footer">
          &copy; <%= new Date().getFullYear() %> SUKAFTI &mdash; FTI Universitas Andalas
        </p>

      </div>
    </main>

  </div>

  <script>
    lucide.createIcons();

    function togglePw(id, btn) {
      const inp = document.getElementById(id);
      const ico = btn.querySelector('i[data-lucide]');
      const hidden = inp.type === 'password';
      inp.type = hidden ? 'text' : 'password';
      ico.setAttribute('data-lucide', hidden ? 'eye-off' : 'eye');
      lucide.createIcons();
    }

    let currentSlide = 0;
    let autoTimer = null;
    const TOTAL = 3;
    const AUTO_MS = 4000;
    const slides = document.querySelectorAll('.carousel__slide');
    const dots = document.querySelectorAll('.panel-left__dots .dot');

    function showSlide(idx) {
      idx = (idx + TOTAL) % TOTAL;
      slides.forEach((s, i) => {
        s.classList.toggle('carousel__slide--active', i === idx);
        s.classList.toggle('carousel__slide--prev', i === currentSlide && i !== idx);
      });
      dots.forEach((d, i) => {
        const active = i === idx;
        d.classList.toggle('dot--active', active);
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      currentSlide = idx;
    }

    function goToSlide(idx) { showSlide(idx); resetTimer(); }
    function nextSlide() { showSlide(currentSlide + 1); }
    function resetTimer() { clearInterval(autoTimer); autoTimer = setInterval(nextSlide, AUTO_MS); }
    resetTimer();
  </script>
</body>

</html>