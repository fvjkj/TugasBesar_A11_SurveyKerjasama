<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Kerjasama | SUKAFTI</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/survey.css">
</head>

<body>
    <div class="survey-container">

        <div class="survey-header">
            <h1>Survey Kerjasama Mitra Industri</h1>
            <p>
                Terima kasih telah berpartisipasi dalam survey kerja sama
                Fakultas Teknologi Informasi Universitas Andalas.
             </p>
        </div>

        <form action="/survey-kerjasama" method="POST" class="survey-form">

            <div class="form-card">
                <h2>Identitas Perusahaan</h2>

                <div class="form-group">
                    <label>Nama Perusahaan</label>
                    <input type="text" value="<%= mitraName || 'Perusahaan Mitra' %>" readonly>
                </div>
            </div>

            <div class="form-card">
                <h2>Penilaian Kerjasama</h2>

                <div class="form-group">
                 <label>Bagaimana kualitas kerja sama dengan FTI?</label>

                    <select name="kualitas_kerjasama" required>
                        <option value="">-- Pilih Penilaian --</option>
                        <option value="Sangat Baik">Sangat Baik</option>
                        <option value="Baik">Baik</option>
                        <option value="Cukup">Cukup</option>
                        <option value="Kurang">Kurang</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Apakah lulusan FTI sesuai kebutuhan industri?</label>

                    <textarea
                        name="evaluasi_lulusan"
                        rows="5"
                        placeholder="Tuliskan pendapat Anda..."
                        required></textarea>
                </div>

                <div class="form-group">
                    <label>Saran untuk peningkatan kerja sama</label>
                     <textarea
                        name="saran"
                        rows="5"
                        placeholder="Masukkan saran..."
                        required></textarea>
                </div>
            </div>

            <button type="submit" class="submit-btn">
                Kirim Survey
            </button>

        </form>

    </div>

</body>
</html>